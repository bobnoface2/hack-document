{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": "dist/server.cjs",
  "pkg": {
    "assets": [
      "dist/**/*",
      "HackDocumentPRO_Data.json"
    ]
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:exe": "npm run build && npx pkg . --targets node18-win-x64 --output documestre.exe",
    "preview": "vite preview",
    "start": "NODE_ENV=production node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/pdfkit": "^0.17.6",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "nodemailer": "^8.0.7",
    "open": "^11.0.0",
    "pdfjs-dist": "^5.7.284",
    "pdfkit": "^0.18.0",
    "pkg": "^5.8.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tesseract.js": "^7.0.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
